{
  "id": "weather",
  "name": "Weather",
  "version": "1.1.0",
  "description": "Display current weather conditions with temperature, humidity, and wind speed",
  "author": "FiestaBoard Team",
  "repository": "https://github.com/Fiestaboard/fiestaboard-plugin--weather",
  "documentation": "README.md",
  "icon": "cloud-sun",
  "category": "weather",
  "min_refresh_seconds": 60,
  "settings_schema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "title": "Enable Weather",
        "default": false
      },
      "provider": {
        "type": "string",
        "title": "Weather Provider",
        "description": "Choose your weather data provider",
        "enum": [
          "weatherapi",
          "openweathermap"
        ],
        "default": "weatherapi"
      },
      "api_key": {
        "type": "string",
        "title": "API Key",
        "description": "Your weather provider API key",
        "ui:widget": "password"
      },
      "locations": {
        "type": "array",
        "title": "Locations",
        "description": "Weather locations to monitor (max 4)",
        "minItems": 1,
        "maxItems": 4,
        "items": {
          "type": "object",
          "properties": {
            "location": {
              "type": "string",
              "title": "Location",
              "description": "City name, zip code, or coordinates"
            },
            "name": {
              "type": "string",
              "title": "Display Name",
              "description": "Short name for display (e.g., HOME, WORK)",
              "maxLength": 10
            }
          },
          "required": [
            "location",
            "name"
          ]
        }
      },
      "refresh_seconds": {
        "type": "integer",
        "title": "Refresh Interval (seconds)",
        "description": "How often to fetch new weather data",
        "default": 300,
        "minimum": 60,
        "maximum": 3600
      }
    },
    "required": [
      "api_key",
      "locations"
    ]
  },
  "env_vars": [
    {
      "name": "WEATHER_API_KEY",
      "required": true,
      "description": "API key from WeatherAPI or OpenWeatherMap"
    },
    {
      "name": "WEATHER_PROVIDER",
      "required": false,
      "description": "Weather provider: weatherapi (default) or openweathermap",
      "default": "weatherapi"
    },
    {
      "name": "WEATHER_LOCATION",
      "required": false,
      "description": "Default location (city name, zip, or coordinates)"
    },
    {
      "name": "WEATHER_REFRESH_SECONDS",
      "required": false,
      "description": "Refresh interval in seconds",
      "default": "300"
    }
  ],
  "variables": {
    "groups": {
      "temperature": {
        "label": "Temperature"
      },
      "conditions": {
        "label": "Conditions"
      },
      "location_info": {
        "label": "Location"
      },
      "display": {
        "label": "Display"
      }
    },
    "simple": {
      "temperature": {
        "description": "Current temperature in Fahrenheit",
        "type": "number",
        "max_length": 3,
        "group": "temperature",
        "example": "72"
      },
      "temperature_c": {
        "description": "Current temperature in Celsius",
        "type": "number",
        "max_length": 3,
        "group": "temperature",
        "example": "22"
      },
      "feels_like": {
        "description": "Feels-like temperature in Fahrenheit",
        "type": "number",
        "max_length": 3,
        "group": "temperature",
        "example": "74"
      },
      "feels_like_c": {
        "description": "Feels-like temperature in Celsius",
        "type": "number",
        "max_length": 3,
        "group": "temperature",
        "example": "23"
      },
      "high_temp": {
        "description": "Daily high temperature in Fahrenheit",
        "type": "number",
        "max_length": 3,
        "group": "temperature",
        "example": "78"
      },
      "high_temp_c": {
        "description": "Daily high temperature in Celsius",
        "type": "number",
        "max_length": 3,
        "group": "temperature",
        "example": "26"
      },
      "low_temp": {
        "description": "Daily low temperature in Fahrenheit",
        "type": "number",
        "max_length": 3,
        "group": "temperature",
        "example": "55"
      },
      "low_temp_c": {
        "description": "Daily low temperature in Celsius",
        "type": "number",
        "max_length": 3,
        "group": "temperature",
        "example": "13"
      },
      "condition": {
        "description": "Weather condition text (e.g., Sunny, Cloudy, Rain)",
        "type": "string",
        "max_length": 12,
        "group": "conditions",
        "example": "Partly Cloudy"
      },
      "humidity": {
        "description": "Humidity percentage",
        "type": "number",
        "max_length": 3,
        "group": "conditions",
        "example": "65"
      },
      "wind_speed": {
        "description": "Wind speed in mph",
        "type": "number",
        "max_length": 3,
        "group": "conditions",
        "example": "12"
      },
      "precipitation_chance": {
        "description": "Chance of precipitation as percentage",
        "type": "number",
        "max_length": 3,
        "group": "conditions",
        "example": "20"
      },
      "uv_index": {
        "description": "UV index value",
        "type": "number",
        "max_length": 2,
        "group": "conditions",
        "example": "6"
      },
      "sunset": {
        "description": "Sunset time",
        "type": "string",
        "max_length": 8,
        "group": "conditions",
        "example": "7:42 PM"
      },
      "temperature_color": {
        "description": "Color code based on temperature",
        "type": "string",
        "max_length": 4,
        "group": "display",
        "example": "{63}"
      },
      "uv_index_color": {
        "description": "Color code based on UV index",
        "type": "string",
        "max_length": 4,
        "group": "display",
        "example": "{65}"
      },
      "location": {
        "description": "Full location string from provider",
        "type": "string",
        "max_length": 15,
        "group": "location_info",
        "example": "San Francisco"
      },
      "location_name": {
        "description": "Display name for the location",
        "type": "string",
        "max_length": 10,
        "group": "location_info",
        "example": "HOME"
      },
      "location_count": {
        "description": "Number of monitored locations",
        "type": "number",
        "max_length": 1,
        "group": "location_info",
        "example": "2"
      }
    },
    "arrays": {
      "locations": {
        "label_field": "location_name",
        "item_fields": [
          "temperature",
          "temperature_c",
          "feels_like",
          "feels_like_c",
          "condition",
          "humidity",
          "wind_speed",
          "location",
          "location_name",
          "precipitation_chance",
          "high_temp",
          "high_temp_c",
          "low_temp",
          "low_temp_c",
          "uv_index",
          "sunset"
        ]
      },
      "forecast": {
        "label_field": "day_name",
        "item_fields": [
          "date",
          "day_name",
          "high_temp",
          "high_temp_c",
          "low_temp",
          "low_temp_c",
          "condition",
          "precipitation_chance",
          "temperature_color"
        ]
      }
    }
  },
  "max_lengths": {
    "locations.*.temperature": 3,
    "locations.*.temperature_c": 3,
    "locations.*.feels_like": 3,
    "locations.*.feels_like_c": 3,
    "locations.*.condition": 12,
    "locations.*.humidity": 3,
    "locations.*.wind_speed": 3,
    "locations.*.location": 15,
    "locations.*.location_name": 10,
    "locations.*.precipitation_chance": 3,
    "locations.*.high_temp": 3,
    "locations.*.high_temp_c": 3,
    "locations.*.low_temp": 3,
    "locations.*.low_temp_c": 3,
    "locations.*.uv_index": 2,
    "locations.*.sunset": 8,
    "forecast.*.date": 10,
    "forecast.*.day_name": 3,
    "forecast.*.high_temp": 3,
    "forecast.*.high_temp_c": 3,
    "forecast.*.low_temp": 3,
    "forecast.*.low_temp_c": 3,
    "forecast.*.condition": 12,
    "forecast.*.precipitation_chance": 3,
    "forecast.*.temperature_color": 6
  },
  "color_rules_schema": {
    "temperature": {
      "type": "threshold",
      "description": "Color based on temperature value",
      "default_rules": [
        {
          "condition": ">=",
          "value": 90,
          "color": "red"
        },
        {
          "condition": ">=",
          "value": 75,
          "color": "orange"
        },
        {
          "condition": ">=",
          "value": 60,
          "color": "green"
        },
        {
          "condition": ">=",
          "value": 45,
          "color": "blue"
        },
        {
          "condition": "<",
          "value": 45,
          "color": "violet"
        }
      ]
    },
    "uv_index": {
      "type": "threshold",
      "description": "Color based on UV index value (standard UV index color scheme)",
      "default_rules": [
        {
          "condition": ">=",
          "value": 11,
          "color": "violet"
        },
        {
          "condition": ">=",
          "value": 8,
          "color": "red"
        },
        {
          "condition": ">=",
          "value": 6,
          "color": "orange"
        },
        {
          "condition": ">=",
          "value": 3,
          "color": "yellow"
        },
        {
          "condition": "<",
          "value": 3,
          "color": "green"
        }
      ]
    }
  },
  "fiestaboard_version": ">=2.10.0",
  "screenshots": [
    {
      "src": "docs/board-display.png",
      "alt": "Weather displayed on a Vestaboard",
      "caption": "Display current weather conditions with temperature, humidity, and wind speed",
      "primary": true
    }
  ],
  "demo": {
    "name": "Weather Demo",
    "device_type": "flagship",
    "template": [
      "{white}{white}   {{weather.location}}  {white}{white}",
      "{white}  {{datetime.date}}  {{datetime.time}} {white}",
      "NOW  {{weather.temperature}}F   {{weather.condition}}    {{weather.humidity}}%",
      "LIKE {{weather.feels_like}}F WIND {{weather.wind_speed}}  MPH",
      "HIGH {{weather.high_temp}}F  UV {{weather.uv_index}}{{weather.uv_index_color}}",
      "LOW {{weather.low_temp}}F  SET {{weather.sunset}}"
    ],
    "line_metadata": [
      {
        "alignment": "left",
        "wrap": false
      },
      {
        "alignment": "left",
        "wrap": false
      },
      {
        "alignment": "left",
        "wrap": false
      },
      {
        "alignment": "left",
        "wrap": false
      },
      {
        "alignment": "left",
        "wrap": false
      },
      {
        "alignment": "left",
        "wrap": false
      }
    ]
  }
}
